import re
import json

def preprocess_vlm_output(input_file, clean_xml_file, context_file):
    metadata = {
        "current_dsn": "UNKNOWN",
        "libraries": []
    }
    
    # Regex pour capturer les informations clés
    re_dsn = re.compile(r"DSNIN=([\w\.]+)")
    re_count = re.compile(r"FMNBB437\s+(\d+)\s+member\(s\) read")
    re_empty = re.compile(r"FMNBE329\s+The PDS contains no members")
    re_error = re.compile(r"FMNBF427\s+(.*)")

    with open(input_file, 'r') as f_in, open(clean_xml_file, 'w') as f_out:
        f_out.write('<?xml version="1.0" encoding="UTF-8"?>\n<root>\n')
        
        current_lib_info = None

        for line in f_in:
            line_str = line.strip()
            
            # 1. Extraction des métadonnées (Metadata Scraping)
            # Recherche du nom de la bibliothèque (DSNIN)
            dsn_match = re_dsn.search(line_str)
            if dsn_match:
                metadata["current_dsn"] = dsn_match.group(1)
                current_lib_info = {
                    "dsn": metadata["current_dsn"],
                    "members_read": 0,
                    "errors": [],
                    "status": "processed"
                }
                [span_0](start_span)[span_1](start_span)metadata["libraries"].append(current_lib_info)[span_0](end_span)[span_1](end_span)

            # Capture des erreurs de module (Binder error)
            error_match = re_error.search(line_str)
            if error_match and current_lib_info:
                [span_2](start_span)[span_3](start_span)current_lib_info["errors"].append(error_match.group(1))[span_2](end_span)[span_3](end_span)
                # Optionnel: on peut insérer un marqueur dans le XML pour signaler l'erreur
                f_out.write(f'\n')

            # Capture du nombre de modules traités
            count_match = re_count.search(line_str)
            if count_match and current_lib_info:
                [span_4](start_span)[span_5](start_span)current_lib_info["members_read"] = int(count_match.group(1))[span_4](end_span)[span_5](end_span)

            # Gestion des bibliothèques vides
            if re_empty.search(line_str) and current_lib_info:
                [span_6](start_span)[span_7](start_span)current_lib_info["status"] = "empty"[span_6](end_span)[span_7](end_span)

            # 2. Filtrage du flux XML (Sanitization)
            # On ne garde que les lignes qui ressemblent à du XML
            if line_str.startswith('<') and not line_str.startswith('1$$FILEM'):
                # Nettoyage des caractères parasites en début de ligne (ex: '0' ou '1')
                clean_line = re.sub(r'^[0-1]', '', line_str)
                f_out.write(clean_line + '\n')

        f_out.write('</root>')

    # Sauvegarde des métadonnées pour la phase JQ
    with open(context_file, 'w') as f_meta:
        json.dump(metadata, f_meta, indent=4)

# Utilisation
preprocess_vlm_output('output_mainframe.txt', 'clean_output.xml', 'context.json')
